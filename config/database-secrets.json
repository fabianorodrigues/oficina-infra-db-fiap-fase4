{
  "version": 1,
  "rds": {
    "endpointParameter": "/oficina/infra/rds/endpoint",
    "portParameter": "/oficina/infra/rds/port"
  },
  "connection": {
    "encrypt": true,
    "trustServerCertificate": false,
    "connectTimeoutSeconds": 30
  },
  "targets": [
    {
      "id": "cadastro-runtime",
      "secretName": "/oficina/cadastro/runtime-db",
      "passwordEnvironmentVariable": "SQL_CADASTRO_APP_PASSWORD",
      "database": "OficinaCadastroDb",
      "username": "cadastro_app"
    },
    {
      "id": "cadastro-migration",
      "secretName": "/oficina/cadastro/migration-db",
      "passwordEnvironmentVariable": "SQL_CADASTRO_MIGRATOR_PASSWORD",
      "database": "OficinaCadastroDb",
      "username": "cadastro_migrator"
    },
    {
      "id": "estoque-runtime",
      "secretName": "/oficina/estoque/runtime-db",
      "passwordEnvironmentVariable": "SQL_ESTOQUE_APP_PASSWORD",
      "database": "OficinaEstoqueDb",
      "username": "estoque_app"
    },
    {
      "id": "estoque-migration",
      "secretName": "/oficina/estoque/migration-db",
      "passwordEnvironmentVariable": "SQL_ESTOQUE_MIGRATOR_PASSWORD",
      "database": "OficinaEstoqueDb",
      "username": "estoque_migrator"
    },
    {
      "id": "ordens-runtime",
      "secretName": "/oficina/ordens/runtime-db",
      "passwordEnvironmentVariable": "SQL_ORDENS_APP_PASSWORD",
      "database": "OficinaOrdensServicoDb",
      "username": "ordens_app"
    },
    {
      "id": "ordens-migration",
      "secretName": "/oficina/ordens/migration-db",
      "passwordEnvironmentVariable": "SQL_ORDENS_MIGRATOR_PASSWORD",
      "database": "OficinaOrdensServicoDb",
      "username": "ordens_migrator"
    },
    {
      "id": "auth-read",
      "secretName": "/oficina/auth/database",
      "passwordEnvironmentVariable": "SQL_AUTH_READ_PASSWORD",
      "database": "OficinaCadastroDb",
      "username": "auth_read"
    }
  ]
}
